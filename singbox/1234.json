{
  "version": 1,
  "rules": [
    {
      "process_name": [
        "Telegram.exe",
        "WeChat.exe"
      ]
    },
    {
      "port": [
        443
      ]
    },
    {
      "port_range": [
        "8080-8089"
      ]
    },
    {
      "domain": [
        "co.uk",
        "www.dash-prefix.com",
        "www.dirty-quote.com",
        "www.double-quote.com",
        "www.google.com",
        "www.speedtest.net"
      ]
    },
    {
      "domain_suffix": [
        "apple.com",
        "sub.video.netflix.com",
        "xn--158h.com",
        "xn--eqrt2gbuz51p87oi1r.xn--fiqs8s"
      ]
    },
    {
      "domain_keyword": [
        "payload",
        "secure",
        "torrent"
      ]
    },
    {
      "ip_cidr": [
        "192.168.1.5/24",
        "2001:db8::1/128"
      ]
    },
    {
      "domain_regex": [
        "^.*\\.le.*video\\.com$",
        "^\\+\\..*\\.firebaseio\\.com$",
        "^bad_domain\\.com/path.query=123$",
        "^https?:\\/\\/.*\\.byteoversea\\.com\\/amap"
      ]
    }
  ]
}