{
  "version": 1,
  "rules": [
    {
      "domain_suffix": [
        "github.com",
        "netflix.com",
        "telegram.org"
      ]
    },
    {
      "domain": [
        "images.unsplash.com"
      ]
    },
    {
      "domain_keyword": [
        "spotify",
        "youtube"
      ]
    },
    {
      "process_name": [
        "DownloadService",
        "com.tencent.xin"
      ]
    },
    {
      "port": [
        22,
        443
      ]
    },
    {
      "domain_regex": [
        "^.*-matrix\\.tg\\.me$",
        "^.*\\.internal\\.crop\\.net$"
      ]
    },
    {
      "ip_cidr": [
        "10.10.10.10/32",
        "192.168.1.1/24",
        "240e:97c:2f:1::/64",
        "fe80::1/128"
      ]
    }
  ]
}