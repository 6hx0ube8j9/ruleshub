{
  "version": 2,
  "rules": [
    {
      "domain": [
        "xn--fiqs8s.xn--fiqs8s",
        "youtube.com"
      ]
    },
    {
      "domain_suffix": [
        "a.b",
        "apple.com",
        "google.com",
        "xn--ldrr30i.xn--fiqs8s"
      ]
    },
    {
      "ip_cidr": [
        "1.1.1.1/32",
        "192.168.1.1/24",
        "2001:db8::/32",
        "2001:db8::1/128"
      ]
    },
    {
      "domain_regex": [
        "^(.+\\.)?google\\.com$",
        "^.*netflix\\.com$",
        "^.*twitter.*$"
      ]
    },
    {
      "process_name": [
        "my custom app.exe"
      ]
    },
    {
      "port": [
        443
      ],
      "port_range": [
        "8080:8090"
      ]
    }
  ]
}