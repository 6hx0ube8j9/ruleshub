{
  "version": 2,
  "rules": [
    {
      "domain": [
        "xn--fiqs8s.xn--fiqs8s"
      ]
    },
    {
      "domain_suffix": [
        "internal.1234567890",
        "xn--ldrr30i.sub.xn--fiqs8s"
      ]
    },
    {
      "domain_regex": [
        "^.*$",
        "^.*google.*$",
        "^.*with\\-dash\\-and_underscore.*$",
        "^\\..*\\..*\\.netflix\\.\\.com$",
        "^my\\+\\$app\\$\\.com$"
      ]
    },
    {
      "process_name": [
        "c:\\program files (x86)\\my \"cool\" app\\test.exe"
      ]
    },
    {
      "port": [
        0,
        80,
        65535
      ],
      "port_range": [
        "1:65535"
      ]
    }
  ]
}